<?xml version="1.0" encoding="utf-8"?>
<!--
  Projection screen (Vehicle category, native car-app only).

  Cast an installed app onto the driver-cluster display and mirror it here, with
  tap/swipe forwarded back. The mirror PIXELS are composited by the daemon onto a
  head-unit SurfaceControl layer that floats over [projectionMirrorPane]; this layout
  only owns the pane geometry + a transparent touch-catcher (see ProjectionFragment).

  IDs (ProjectionFragment.kt findViewById targets):
    projectionAppSpinner / projectionCastButton / projectionStopButton
    projectionStatus / projectionMirrorPane / projectionTouchCatcher / projectionProgress
-->
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:fillViewport="true"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:animateLayoutChanges="true"
        android:paddingHorizontal="@dimen/page_padding_horizontal"
        android:paddingTop="@dimen/page_padding_top"
        android:paddingBottom="@dimen/page_padding_bottom"
        android:clipToPadding="false">

        <!-- ================== HERO ================== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/projection_hero_title"
            android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
            android:textColor="?attr/colorOnSurface"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/projection_hero_subtitle"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <!-- ================== CAST CONTROLS ================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/card_gap_vertical"
            android:background="@drawable/dialog_m3_background"
            android:orientation="vertical"
            android:padding="@dimen/card_padding_standard">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/projection_pick_app"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textColor="?attr/colorOnSurface" />

            <Spinner
                android:id="@+id/projectionAppSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:minHeight="48dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/projectionCastButton"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="@string/projection_cast" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/projectionStopButton"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:enabled="false"
                    android:text="@string/projection_stop" />
            </LinearLayout>

            <TextView
                android:id="@+id/projectionStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/projection_status_idle"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <!-- Adjust bounds toggle: enters ADJUST mode so the user can drag/resize the
                 draggable bounding rectangle the mirror is projected into. -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/projectionAdjustButton"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:enabled="false"
                android:text="@string/projection_adjust_bounds" />
        </LinearLayout>

        <!-- ================== SCALING MODE ================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/card_gap_vertical"
            android:background="@drawable/dialog_m3_background"
            android:orientation="vertical"
            android:padding="@dimen/card_padding_standard">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/projection_scale_title"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textColor="?attr/colorOnSurface" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/projection_scale_desc"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/projectionScaleGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:selectionRequired="true"
                app:singleSelection="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/projectionScaleFit"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/projection_scale_fit" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/projectionScaleFill"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/projection_scale_fill" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/projectionScaleZoom"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/projection_scale_zoom" />
            </com.google.android.material.button.MaterialButtonToggleGroup>

            <!-- ============ AUTO-START ON ACC-ON ============ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/projection_autostart_title"
                        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                        android:textColor="?attr/colorOnSurface" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/projection_autostart_desc"
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/projectionAutoStartSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical" />
            </LinearLayout>
        </LinearLayout>

        <!-- ================== MIRROR STAGE ==================
             The daemon composites the live cluster onto a head-unit SurfaceControl layer
             sized to the bounding rect the user sets in [projectionBounds]. That layer
             floats ABOVE this window, so ProjectionBoundsView draws its resize handles
             OUTSIDE the box (visible beside the mirror) and forwards touches to the cluster
             in control mode. The dark backdrop shows before the mirror lands / when idle. -->
        <FrameLayout
            android:id="@+id/projectionStage"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:layout_marginTop="@dimen/card_gap_vertical"
            android:background="@android:color/black">

            <com.overdrive.app.ui.view.ProjectionBoundsView
                android:id="@+id/projectionBounds"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <ProgressBar
                android:id="@+id/projectionProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone" />
        </FrameLayout>

        <!-- ================== NOTE ================== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/card_gap_vertical"
            android:text="@string/projection_note_single_app"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="?attr/colorOnSurfaceVariant" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
